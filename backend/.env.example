# ===========================================
# OncoVisionX — Skin Cancer Triage CDSS
# ===========================================

# Server Configuration
NODE_ENV=development
PORT=5000

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/oncovisionx

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_REFRESH_EXPIRE=30d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# FastAPI ML Service URL
FASTAPI_URL=http://localhost:8000

# Email Configuration (Optional)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=
FROM_NAME=OncoVisionX

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Root Admin Credentials (for initial setup only)
ROOT_ADMIN_EMAIL=admin@oncovisionx.com
ROOT_ADMIN_PASSWORD=ChangeThisSecurePassword123!
ROOT_ADMIN_FIRST_NAME=System
ROOT_ADMIN_LAST_NAME=Administrator
